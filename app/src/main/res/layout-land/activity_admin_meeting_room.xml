<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_green"
    android:orientation="vertical">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:contentDescription="@string/btn_back"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/white" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/meeting_room_title"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <View
            android:layout_width="28dp"
            android:layout_height="28dp" />
    </LinearLayout>

    <!-- Grid: 4 per row in landscape -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp">

            <!-- Row 1: 4 tiles -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:orientation="horizontal">

                <!-- Tile 1 -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_video_rounded" />

                    <ImageView
                        android:id="@+id/prohibitBtn1"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="bottom|end"
                        android:layout_margin="6dp"
                        android:contentDescription="@string/meeting_room_title"
                        android:src="@drawable/ic_prohibited"
                        app:tint="@color/red_prohibited" />
                </FrameLayout>

                <!-- Tile 2 -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_video_rounded" />

                    <ImageView
                        android:id="@+id/prohibitBtn2"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="bottom|end"
                        android:layout_margin="6dp"
                        android:contentDescription="@string/meeting_room_title"
                        android:src="@drawable/ic_prohibited"
                        app:tint="@color/red_prohibited" />
                </FrameLayout>

                <!-- Tile 3 -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_video_rounded" />

                    <ImageView
                        android:id="@+id/prohibitBtn3"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="bottom|end"
                        android:layout_margin="6dp"
                        android:contentDescription="@string/meeting_room_title"
                        android:src="@drawable/ic_prohibited"
                        app:tint="@color/red_prohibited" />
                </FrameLayout>

                <!-- Tile 4 -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_video_rounded" />

                    <ImageView
                        android:id="@+id/prohibitBtn4"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="bottom|end"
                        android:layout_margin="6dp"
                        android:contentDescription="@string/meeting_room_title"
                        android:src="@drawable/ic_prohibited"
                        app:tint="@color/red_prohibited" />
                </FrameLayout>
            </LinearLayout>

            <!-- Row 2: 1 tile + 3 empty placeholders -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Tile 5 -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_video_rounded" />

                    <ImageView
                        android:id="@+id/prohibitBtn5"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="bottom|end"
                        android:layout_margin="6dp"
                        android:contentDescription="@string/meeting_room_title"
                        android:src="@drawable/ic_prohibited"
                        app:tint="@color/red_prohibited" />
                </FrameLayout>

                <!-- Empty placeholders to maintain grid alignment -->
                <View
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>