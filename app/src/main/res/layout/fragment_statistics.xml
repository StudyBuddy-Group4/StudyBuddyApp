<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_top"
    android:orientation="vertical">

    <!-- Statistics page -->
    <!-- Shows rating, focus time, and session history -->
    <!-- Summary stays above the history list -->
    <!-- Screen title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="20dp"
        android:text="@string/statistics_title"
        android:textColor="@color/dark_text"
        android:textSize="20sp"
        android:textStyle="bold" />

    <!-- White content card -->
    <!-- Scrolls when the history list gets long -->
    <!-- Main body of the page -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_card_white"
        android:elevation="2dp"
        android:fillViewport="true">

        <!-- Page content -->
        <!-- Keeps all statistics in one vertical column -->
        <!-- Centered so the summary stays aligned -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Personal Rating -->
            <!-- Rating row -->
            <!-- Places the score beside the help icon -->
            <!-- First summary block -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Rating value -->
                <!-- Filled with the current personal score -->
                <TextView
                    android:id="@+id/tvRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.0"
                    android:textColor="@color/dark_text"
                    android:textSize="48sp"
                    android:textStyle="bold" />

                <!-- Rating help icon -->
                <!-- Opens the explanation dialog -->
                <!-- Small clickable icon beside the score -->
                <ImageView
                    android:id="@+id/ic_question"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginBottom="20dp"
                    android:clickable="true"
                    android:contentDescription="@string/how_rating_calculated"
                    android:focusable="true"
                    android:src="@drawable/ic_question_mark" />
            </LinearLayout>

            <!-- Rating label -->
            <!-- Caption under the score -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/personal_rating"
                android:textColor="@color/secondary_text"
                android:textSize="14sp" />

            <!-- Accumulated Focus Time -->
            <!-- Focus time value -->
            <!-- Second summary block -->
            <TextView
                android:id="@+id/tvFocusTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="0h 0m"
                android:textColor="@color/dark_text"
                android:textSize="36sp"
                android:textStyle="bold" />

            <!-- Focus time label -->
            <!-- Caption under the total time -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/accumulated_focus_time"
                android:textColor="@color/secondary_text"
                android:textSize="14sp" />

            <!-- Divider -->
            <!-- Separates the summary from the history list -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="16dp"
                android:background="@color/input_field_bg" />

            <!-- Dynamic session history container -->
            <!-- History rows are added here at runtime -->
            <!-- Starts empty in XML -->
            <LinearLayout
                android:id="@+id/sessionHistoryContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Empty state -->
            <!-- Shown when there are no session history rows -->
            <!-- Hidden once at least one history row is added -->
            <TextView
                android:id="@+id/tvEmptyHistory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="24dp"
                android:text="@string/empty_sessions_message"
                android:textColor="@color/secondary_text"
                android:textSize="14sp"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
