<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_green">

    <!-- Create account screen -->
    <!-- Green header on top -->
    <!-- White card holds the full sign-up form -->

    <!-- Top header background -->
    <!-- Fills the top header area -->
    <View
        android:id="@+id/headerBackground"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_gradient_green"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.18" />

    <!-- Back action -->
    <!-- Returns to the previous screen -->
    <ImageView
        android:id="@+id/ivBack"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/ic_arrow_back"
        android:contentDescription="@string/btn_back"
        app:tint="@color/white"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Screen title -->
    <!-- Main heading for the sign-up page -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/create_account"
        android:textColor="@color/white"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/headerBackground"
        app:layout_constraintBottom_toBottomOf="@id/headerBackground"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Scrollable white card -->
    <!-- Holds the full sign-up form -->
    <!-- Lets the full form stay visible on shorter screens -->
    <ScrollView
        android:id="@+id/cardContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_card_white"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/headerBackground"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Form content -->
        <!-- Stacks all fields, the sign-up button, and the footer link -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Username label -->
            <!-- Label for the username field -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/username"
                style="@style/FieldLabel"
                android:layout_marginTop="16dp" />

            <!-- Username input -->
            <!-- Editable username field -->
            <EditText
                android:id="@+id/etUsername"
                style="@style/InputField"
                android:layout_marginTop="8dp"
                android:hint="@string/hint_username"
                android:inputType="text"
                android:importantForAutofill="no" />

            <!-- Email label -->
            <!-- Label for the email field -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/email"
                style="@style/FieldLabel"
                android:layout_marginTop="16dp" />

            <!-- Email input -->
            <!-- Editable email field -->
            <EditText
                android:id="@+id/etEmail"
                style="@style/InputField"
                android:layout_marginTop="8dp"
                android:hint="@string/hint_email"
                android:inputType="textEmailAddress"
                android:importantForAutofill="no" />

            <!-- Password label -->
            <!-- Label for the password field -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/password"
                style="@style/FieldLabel"
                android:layout_marginTop="16dp" />

            <!-- Password field row -->
            <!-- Input and toggle stay in one row -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp">

                <!-- Password input -->
                <!-- Main password field -->
                <EditText
                    android:id="@+id/etPassword"
                    style="@style/InputField"
                    android:hint="@string/password"
                    android:inputType="textPassword"
                    android:importantForAutofill="no" />

                <!-- Password visibility toggle -->
                <!-- Shows or hides the password field -->
                <ImageView
                    android:id="@+id/ivTogglePassword"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="end|center_vertical"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/ic_visibility_off"
                    android:contentDescription="Toggle password visibility" />
            </FrameLayout>

            <!-- Confirm password label -->
            <!-- Label for the confirmation field -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/confirm_password"
                style="@style/FieldLabel"
                android:layout_marginTop="16dp" />

            <!-- Confirm password field row -->
            <!-- Input and toggle stay in one row -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp">

                <!-- Confirm password input -->
                <!-- Repeats the password for confirmation -->
                <EditText
                    android:id="@+id/etConfirmPassword"
                    style="@style/InputField"
                    android:hint="@string/confirm_password"
                    android:inputType="textPassword"
                    android:importantForAutofill="no" />

                <!-- Confirm password visibility toggle -->
                <!-- Shows or hides the confirmation field -->
                <ImageView
                    android:id="@+id/ivToggleConfirmPassword"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="end|center_vertical"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/ic_visibility_off"
                    android:contentDescription="Toggle password visibility" />
            </FrameLayout>

            <!-- Sign Up button -->
            <!-- Main action for creating the account -->
            <Button
                android:id="@+id/btnSignUp"
                style="@style/PrimaryButton"
                android:layout_width="match_parent"
                android:text="@string/btn_sign_up"
                android:layout_marginTop="28dp" />

            <!-- Already have an account? Log In -->
            <!-- Prompt and login shortcut stay on one line -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="16dp">

                <!-- Prompt text -->
                <!-- Shown before the login shortcut -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/already_have_account"
                    android:textColor="@color/secondary_text"
                    android:textSize="14sp" />

                <!-- Login -->
                <!-- Returns to the login flow -->
                <TextView
                    android:id="@+id/tvLogIn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_log_in"
                    android:textColor="@color/primary_green"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginStart="6dp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
