<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/very_light_mint">

    <!-- Launch options screen -->
    <!-- Portrait version -->
    <!-- Shows the app branding first -->
    <!-- Login, sign up, and recovery start here -->
    <!-- Light background fills the full screen -->

    <!-- App logo -->
    <!-- Top branding icon -->
    <!-- First element in the portrait stack -->
    <ImageView
        android:id="@+id/ivLogo"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_book_logo"
        android:contentDescription="@string/app_name"
        app:tint="@color/primary_green"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.2" />

    <!-- App name -->
    <!-- Brand title under the logo -->
    <!-- Centered under the icon -->
    <TextView
        android:id="@+id/tvAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/splash_app_name"
        android:textColor="@color/primary_green"
        android:textSize="36sp"
        android:textStyle="bold"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/ivLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Tagline text -->
    <!-- Short description under the app name -->
    <!-- Uses side margins to keep the line readable -->
    <TextView
        android:id="@+id/tvTagline"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/launch_tagline"
        android:textColor="@color/secondary_text"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginTop="12dp"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        app:layout_constraintTop_toBottomOf="@id/tvAppName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Primary login action -->
    <!-- Main entry for existing users -->
    <!-- First button in the action stack -->
    <Button
        android:id="@+id/btnLogIn"
        style="@style/PrimaryButton"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="@string/btn_log_in"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        app:layout_constraintTop_toBottomOf="@id/tvTagline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnSignUp"
        app:layout_constraintVertical_bias="0.5"
        android:layout_marginTop="48dp" />

    <!-- Secondary sign-up action -->
    <!-- Starts the account creation flow -->
    <!-- Second button in the action stack -->
    <Button
        android:id="@+id/btnSignUp"
        style="@style/SecondaryButton"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="@string/btn_sign_up"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnLogIn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Forgot-password-->
    <!-- Starts the recovery flow -->
    <!-- Text link under the two buttons -->
    <TextView
        android:id="@+id/tvForgotPassword"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/forgot_password_link"
        android:textColor="@color/primary_green"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/btnSignUp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
