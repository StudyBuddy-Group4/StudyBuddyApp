<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_green"
    android:orientation="vertical">

    <!-- Root container -->
    <!-- Full-screen admin meeting layout -->

    <!-- Header row -->
    <!-- Top navigation area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp">

        <!-- Back button -->
        <!-- Returns to the previous admin screen -->
        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:contentDescription="@string/btn_back"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/white" />

        <!-- Centered title -->
        <!-- Keeps the room title visually aligned -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/meeting_room_title"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Spacer to balance the back button -->
        <!-- Matches the back icon width on the right -->
        <View
            android:layout_width="28dp"
            android:layout_height="28dp" />
    </LinearLayout>

    <!-- Scrollable participant area -->
    <!-- Horizontal layouts can still grow vertically -->
    <!-- Grid: 4 per row in landscape -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <!-- Static landscape grid wrapper -->
        <!-- Extra side padding centers the rows on wide screens -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="60dp"
            android:paddingEnd="60dp"
            android:paddingBottom="24dp">

            <!-- Row 1: 4 tiles -->
            <!-- First landscape row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:orientation="horizontal">

                <!-- Tile 1 -->
                <!-- Video placeholder with moderation action -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="150dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1">
                    <!-- Tile background -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_video_rounded" />
                    <!-- Prohibit action -->
                    <ImageView
                        android:id="@+id/prohibitBtn1"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="bottom|end"
                        android:layout_margin="8dp"
                        android:contentDescription="@string/meeting_room_title"
                        android:src="@drawable/ic_prohibited"
                        app:tint="@color/red_prohibited" />
                </FrameLayout>

                <!-- Tile 2 -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="150dp"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1">
                    <!-- Tile background -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_video_rounded" />
                    <!-- Prohibit action -->
                    <ImageView
                        android:id="@+id/prohibitBtn2"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="bottom|end"
                        android:layout_margin="8dp"
                        android:contentDescription="@string/meeting_room_title"
                        android:src="@drawable/ic_prohibited"
                        app:tint="@color/red_prohibited" />
                </FrameLayout>

                <!-- Tile 3 -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="150dp"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1">
                    <!-- Tile background -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_video_rounded" />
                    <!-- Prohibit action -->
                    <ImageView
                        android:id="@+id/prohibitBtn3"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="bottom|end"
                        android:layout_margin="8dp"
                        android:contentDescription="@string/meeting_room_title"
                        android:src="@drawable/ic_prohibited"
                        app:tint="@color/red_prohibited" />
                </FrameLayout>

                <!-- Tile 4 -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="150dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1">
                    <!-- Tile background -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_video_rounded" />
                    <!-- Prohibit action -->
                    <ImageView
                        android:id="@+id/prohibitBtn4"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="bottom|end"
                        android:layout_margin="8dp"
                        android:contentDescription="@string/meeting_room_title"
                        android:src="@drawable/ic_prohibited"
                        app:tint="@color/red_prohibited" />
                </FrameLayout>
            </LinearLayout>

            <!-- Row 2: 1 tile + 3 empty -->
            <!-- Partial second row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Tile 5 -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="150dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1">
                    <!-- Tile background -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_video_rounded" />
                    <!-- Prohibit action -->
                    <ImageView
                        android:id="@+id/prohibitBtn5"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="bottom|end"
                        android:layout_margin="8dp"
                        android:contentDescription="@string/meeting_room_title"
                        android:src="@drawable/ic_prohibited"
                        app:tint="@color/red_prohibited" />
                </FrameLayout>

                <!-- Empty spacer cell -->
                <View android:layout_width="0dp" android:layout_height="150dp"
                    android:layout_marginStart="6dp" android:layout_marginEnd="6dp"
                    android:layout_weight="1" />
                <!-- Empty spacer cell -->
                <View android:layout_width="0dp" android:layout_height="150dp"
                    android:layout_marginStart="6dp" android:layout_marginEnd="6dp"
                    android:layout_weight="1" />
                <!-- Empty spacer cell -->
                <View android:layout_width="0dp" android:layout_height="150dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
