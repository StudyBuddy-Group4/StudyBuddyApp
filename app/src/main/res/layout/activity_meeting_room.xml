<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_green">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/meeting_room_title"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Main / speaker video container -->
    <FrameLayout
        android:id="@+id/mainVideoContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bg_video_rounded"
        android:clipToOutline="true"
        app:layout_constraintBottom_toTopOf="@id/thumbnailScroll"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle">

        <!-- Timer bubble overlaid on the main video -->
        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_margin="12dp"
            android:background="@drawable/bg_timer_bubble"
            android:gravity="center"
            android:paddingStart="14dp"
            android:paddingTop="8dp"
            android:paddingEnd="14dp"
            android:paddingBottom="8dp"
            android:text="@string/time_left"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textStyle="bold" />
    </FrameLayout>

    <!-- Horizontal scroll for thumbnail videos -->
    <HorizontalScrollView
        android:id="@+id/thumbnailScroll"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/controlBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:id="@+id/thumbnailContainer"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <!-- Bottom control bar -->
    <LinearLayout
        android:id="@+id/controlBar"
        android:layout_width="0dp"
        android:layout_height="62dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_meeting_control"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/btnSpeaker"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@drawable/bg_circle_control"
            android:contentDescription="@string/meeting_room_title"
            android:padding="11dp"
            android:src="@drawable/ic_speaker" />

        <ImageView
            android:id="@+id/btnCamera"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@drawable/bg_circle_control"
            android:contentDescription="@string/meeting_room_title"
            android:padding="11dp"
            android:src="@drawable/ic_videocam" />

        <ImageView
            android:id="@+id/btnHangUp"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@drawable/bg_circle_red"
            android:contentDescription="@string/meeting_room_title"
            android:padding="11dp"
            android:src="@drawable/ic_call_end" />

        <ImageView
            android:id="@+id/btnMic"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@drawable/bg_circle_control"
            android:contentDescription="@string/meeting_room_title"
            android:padding="11dp"
            android:src="@drawable/ic_mic" />

        <ImageView
            android:id="@+id/btnFlag"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@drawable/bg_circle_control"
            android:contentDescription="@string/flag_title"
            android:padding="11dp"
            android:src="@drawable/ic_flag" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
