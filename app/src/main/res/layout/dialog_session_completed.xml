<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingStart="28dp"
    android:paddingTop="32dp"
    android:paddingEnd="28dp"
    android:paddingBottom="28dp">

    <!-- Session completed dialog -->
    <!-- Shown after a successful focus session -->
    <!-- Completion message -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/session_congratulations"
        android:textColor="@color/dark_text"
        android:textSize="20sp"
        android:textStyle="bold" />

    <!-- Home button -->
    <!-- Returns to the home page -->
    <!-- Primary action in the dialog -->
    <Button
        android:id="@+id/btnHome"
        style="@style/PrimaryButton"
        android:layout_width="240dp"
        android:layout_height="48dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_button_primary"
        android:stateListAnimator="@null"
        android:text="@string/btn_home"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold" />

    <!-- New-session button -->
    <!-- Starts another focus session -->
    <!-- Secondary action under the home button -->
    <Button
        android:id="@+id/btnStartNewSession"
        style="@style/SecondaryButton"
        android:layout_width="240dp"
        android:layout_height="48dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_button_secondary"
        android:stateListAnimator="@null"
        android:text="@string/btn_start_new_session"
        android:textColor="@color/primary_green"
        android:textSize="16sp"
        android:textStyle="bold" />

    <!-- Task-list button -->
    <!-- Opens the task list after the session -->
    <!-- Last option in the action stack -->
    <Button
        android:id="@+id/btnGoToTaskList"
        style="@style/SecondaryButton"
        android:layout_width="240dp"
        android:layout_height="48dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_button_secondary"
        android:stateListAnimator="@null"
        android:text="@string/btn_go_to_task_list"
        android:textColor="@color/primary_green"
        android:textSize="16sp"
        android:textStyle="bold" />

</LinearLayout>
