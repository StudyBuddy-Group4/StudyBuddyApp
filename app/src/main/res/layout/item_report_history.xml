<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <!-- Report history row -->
    <!-- One past moderation decision -->
    <!-- Status icon -->
    <ImageView
        android:id="@+id/ivReportIcon"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:contentDescription="Report status"
        android:src="@drawable/ic_prohibited" />

    <!-- Text block -->
    <!-- Holds the user and action text -->
    <!-- Expands so the date can stay on the right -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Reported user -->
        <!-- Main line of the row -->
        <TextView
            android:id="@+id/tvReportUser"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/dark_text"
            android:textSize="15sp"
            android:textStyle="bold" />

        <!-- Report action -->
        <!-- Describes what the admin did -->
        <TextView
            android:id="@+id/tvReportAction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/secondary_text"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Report date -->
    <!-- Right-side timestamp -->
    <TextView
        android:id="@+id/tvReportDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/secondary_text"
        android:textSize="12sp" />

</LinearLayout>
