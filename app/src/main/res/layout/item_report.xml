<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_warning_box"
    android:layout_marginBottom="12dp"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Pending report row -->
    <!-- One moderation card per report -->
    <!-- Report header -->
    <TextView
        android:id="@+id/tvReportHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/dark_text"
        android:textSize="15sp"
        android:textStyle="bold" />

    <!-- Report details -->
    <!-- Shows the reason or extra report text -->
    <!-- Filled with the report body from code -->
    <TextView
        android:id="@+id/tvReportDetails"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/secondary_text"
        android:textSize="13sp" />

    <!-- Report status -->
    <!-- Color and text are set from code -->
    <!-- Sits above the action buttons -->
    <TextView
        android:id="@+id/tvReportStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textSize="12sp"
        android:textStyle="bold" />

    <!-- Action row -->
    <!-- Contains the moderation buttons -->
    <!-- Right-aligned to keep the text block clear -->
    <LinearLayout
        android:id="@+id/actionButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        android:gravity="end">

        <!-- Dismiss button -->
        <!-- Marks the report as reviewed without a ban -->
        <Button
            android:id="@+id/btnDismiss"
            style="@style/SecondaryButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_button_secondary"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:stateListAnimator="@null"
            android:text="Dismiss"
            android:textColor="@color/primary_green"
            android:textSize="12sp" />

        <!-- Ban 3 days button -->
        <!-- Applies a temporary ban -->
        <Button
            android:id="@+id/btnBan3Days"
            style="@style/PrimaryButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_button_primary"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:stateListAnimator="@null"
            android:text="Ban 3 Days"
            android:textColor="@color/white"
            android:textSize="12sp" />

        <!-- Permanent ban button -->
        <!-- Applies the strongest moderation action -->
        <Button
            android:id="@+id/btnBanPerm"
            style="@style/PrimaryButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/bg_button_primary"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:stateListAnimator="@null"
            android:text="Ban"
            android:textColor="@color/white"
            android:textSize="12sp" />
    </LinearLayout>
</LinearLayout>
