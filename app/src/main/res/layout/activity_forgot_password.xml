<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_green">

    <!-- Forgot password screen -->
    <!-- Portrait version -->
    <!-- Explains the recovery step first -->
    <!-- The email field and next button sit inside the white card -->

    <!-- Top header background -->
    <!-- Green header area -->
    <View
        android:id="@+id/headerBackground"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_gradient_green"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.18" />

    <!-- Back action -->
    <!-- Returns to the previous screen -->
    <ImageView
        android:id="@+id/ivBack"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/ic_arrow_back"
        android:contentDescription="@string/btn_back"
        app:tint="@color/white"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Screen title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/forgot_password_title"
        android:textColor="@color/white"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/headerBackground"
        app:layout_constraintBottom_toBottomOf="@id/headerBackground"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Scrollable white card -->
    <!-- Holds the reset explanation and email form -->
    <!-- Lets the full content stay visible on shorter screens -->
    <ScrollView
        android:id="@+id/cardContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_card_white"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/headerBackground"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Form content -->
        <!-- Stacks the text, email field, and action button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Main reset question -->
            <!-- First line the user reads inside the card -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reset_password_question"
                android:textColor="@color/dark_text"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp" />

            <!-- Supporting explanation -->
            <!-- Adds extra detail below the main question -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/reset_password_desc"
                android:textColor="@color/secondary_text"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"
                android:layout_marginTop="12dp" />

            <!-- Email label -->
            <!-- Label for the recovery email field -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/enter_email_address"
                style="@style/FieldLabel"
                android:layout_marginTop="28dp" />

            <!-- Email input -->
            <!-- Email used for the next recovery step -->
            <EditText
                android:id="@+id/etEmail"
                style="@style/InputField"
                android:layout_marginTop="8dp"
                android:hint="@string/hint_email"
                android:inputType="textEmailAddress"
                android:importantForAutofill="no" />

            <!-- Primary next-step action -->
            <!-- Main action for this screen -->
            <Button
                android:id="@+id/btnNextStep"
                style="@style/PrimaryButton"
                android:layout_width="match_parent"
                android:text="@string/btn_next_step"
                android:layout_marginTop="32dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
