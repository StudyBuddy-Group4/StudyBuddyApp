<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Admin decision dialog -->
    <!-- Opens after the admin selects a moderation target -->
    <!-- Dialog title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/admin_decision_title"
        android:textColor="@color/dark_text"
        android:textSize="18sp"
        android:textStyle="bold" />

    <!-- Kick-out button -->
    <!-- Removes the participant without a ban -->
    <!-- First action in the list -->
    <Button
        android:id="@+id/btnKickOut"
        style="@style/PrimaryButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_button_primary"
        android:stateListAnimator="@null"
        android:text="@string/btn_kick_out"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold" />

    <!-- Temporary ban button -->
    <!-- Applies a three-day ban -->
    <!-- Second action in the list -->
    <Button
        android:id="@+id/btnBan3Days"
        style="@style/PrimaryButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_button_primary"
        android:stateListAnimator="@null"
        android:text="@string/btn_ban_3_days"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold" />

    <!-- Permanent ban button -->
    <!-- Applies permanent ban -->
    <!-- Strongest action in the list -->
    <Button
        android:id="@+id/btnBanPermanently"
        style="@style/PrimaryButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_button_primary"
        android:stateListAnimator="@null"
        android:text="@string/btn_ban_permanently"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold" />

    <!-- Back button -->
    <!-- Closes the dialog without taking action -->
    <!-- Last button in the stack -->
    <Button
        android:id="@+id/btnBack"
        style="@style/SecondaryButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_button_secondary"
        android:stateListAnimator="@null"
        android:text="@string/btn_back"
        android:textSize="16sp"
        android:textStyle="bold" />

</LinearLayout>
