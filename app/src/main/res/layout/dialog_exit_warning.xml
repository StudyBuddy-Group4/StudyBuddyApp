<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingStart="28dp"
    android:paddingTop="32dp"
    android:paddingEnd="28dp"
    android:paddingBottom="28dp">

    <TextView
        android:id="@+id/tvWarningMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/manual_exit_warning"
        android:textColor="@color/dark_text"
        android:textSize="20sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnContinueStudying"
        android:layout_width="240dp"
        android:layout_height="48dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_button_primary"
        android:stateListAnimator="@null"
        android:text="@string/btn_continue_studying"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnLeaveSession"
        android:layout_width="240dp"
        android:layout_height="48dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_button_secondary"
        android:stateListAnimator="@null"
        android:text="@string/btn_leave_session"
        android:textColor="@color/dark_text"
        android:textSize="16sp"
        android:textStyle="bold" />

</LinearLayout>
