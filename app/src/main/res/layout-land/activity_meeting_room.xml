<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_green">

    <!-- Meeting room screen -->
    <!-- Landscape version -->
    <!-- Landscape keeps the main video wide -->
    <!-- Thumbnails and controls stay stacked below -->

    <!-- Screen title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/meeting_room_title"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Main video area -->
    <!-- Uses a 16:9 ratio to stay wide in landscape -->
    <FrameLayout
        android:id="@+id/mainVideoContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="48dp"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="48dp"
        android:layout_marginBottom="6dp"
        android:background="@drawable/bg_video_rounded"
        android:clipToOutline="true"
        app:layout_constraintBottom_toTopOf="@id/thumbnailScroll"
        app:layout_constraintDimensionRatio="16:9"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintVertical_bias="0.5">

        <!-- Speaker label -->
        <!-- Sits over the bottom-left corner of the video -->
        <TextView
            android:id="@+id/tvSpeakerId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:layout_margin="12dp"
            android:background="#88000000"
            android:paddingStart="8dp"
            android:paddingTop="4dp"
            android:paddingEnd="8dp"
            android:paddingBottom="4dp"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- Timer bubble -->
        <!-- Shows the time left in the current session -->
        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_margin="12dp"
            android:background="@drawable/bg_timer_bubble"
            android:gravity="center"
            android:paddingStart="14dp"
            android:paddingTop="8dp"
            android:paddingEnd="14dp"
            android:paddingBottom="8dp"
            android:text="@string/time_left"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textStyle="bold" />
    </FrameLayout>

    <!-- Thumbnail strip -->
    <!-- Shorter row keeps more space for the main video -->
    <!-- Scrolls sideways when there are many participants -->
    <HorizontalScrollView
        android:id="@+id/thumbnailScroll"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="4dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/controlBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Runtime thumbnail container -->
        <!-- Preview cards are added here from code -->
        <LinearLayout
            android:id="@+id/thumbnailContainer"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <!-- Bottom control bar -->
    <!-- Centered so the buttons stay compact in landscape -->
    <!-- Groups the in-call actions in one row -->
    <LinearLayout
        android:id="@+id/controlBar"
        android:layout_width="wrap_content"
        android:layout_height="56dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_meeting_control"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Speaker toggle -->
        <!-- Turns speaker output on or off -->
        <ImageView
            android:id="@+id/btnSpeaker"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_circle_control"
            android:contentDescription="@string/meeting_room_title"
            android:padding="11dp"
            android:src="@drawable/ic_speaker" />

        <!-- Camera toggle -->
        <!-- Turns the local camera on or off -->
        <ImageView
            android:id="@+id/btnCamera"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_circle_control"
            android:contentDescription="@string/meeting_room_title"
            android:padding="11dp"
            android:src="@drawable/ic_videocam" />

        <!-- Hang-up action -->
        <!-- Ends the current room session -->
        <ImageView
            android:id="@+id/btnHangUp"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_circle_red"
            android:contentDescription="@string/meeting_room_title"
            android:padding="11dp"
            android:src="@drawable/ic_call_end" />

        <!-- Microphone toggle -->
        <!-- Turns the microphone on or off -->
        <ImageView
            android:id="@+id/btnMic"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_circle_control"
            android:contentDescription="@string/meeting_room_title"
            android:padding="11dp"
            android:src="@drawable/ic_mic" />

        <!-- Flag-participant action -->
        <!-- Opens the participant reporting flow -->
        <ImageView
            android:id="@+id/btnFlag"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_circle_control"
            android:contentDescription="@string/flag_title"
            android:padding="11dp"
            android:src="@drawable/ic_flag" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
