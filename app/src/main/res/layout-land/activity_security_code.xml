<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_green">

    <!-- Security code screen -->
    <!-- Landscape version -->

    <!-- Used in the password recovery flow -->
    <!-- Green header on top and white card below -->
    <!-- Landscape keeps the same sections with wider padding -->

    <!-- Top header background -->
    <!-- Green header area -->
    <View
        android:id="@+id/headerBackground"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_gradient_green"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.18" />

    <!-- Back action -->
    <!-- Returns to the previous recovery step -->
    <ImageView
        android:id="@+id/ivBack"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/ic_arrow_back"
        android:contentDescription="@string/btn_back"
        app:tint="@color/white"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Screen title -->
    <!-- Centered inside the header block -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/security_code_title"
        android:textColor="@color/white"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/headerBackground"
        app:layout_constraintBottom_toBottomOf="@id/headerBackground"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Scrollable white card -->
    <!-- Keeps the full form visible on shorter screens -->
    <ScrollView
        android:id="@+id/cardContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_card_white"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/headerBackground"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Form content -->
        <!-- Wide side padding -->
        <!-- Stacks the prompt, code row, and buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="250dp"
            android:paddingTop="24dp"
            android:paddingEnd="250dp"
            android:paddingBottom="24dp"
            android:gravity="center_horizontal">

            <!-- Code prompt -->
            <!-- Tells the user what to enter here -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/enter_security_code"
                android:textColor="@color/dark_text"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp" />

            <!-- Security code row -->
            <!-- Six code boxes -->
            <!-- One box for each digit -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="32dp">

                <!-- Code digit 1 -->
                <!-- First number box -->
                <EditText
                    android:id="@+id/etCode1"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_security_code_circle"
                    android:gravity="center"
                    android:maxLength="1"
                    android:inputType="number"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark_text"
                    android:importantForAutofill="no"
                    android:layout_marginEnd="8dp" />

                <!-- Code digit 2 -->
                <!-- Second number box -->
                <EditText
                    android:id="@+id/etCode2"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_security_code_circle"
                    android:gravity="center"
                    android:maxLength="1"
                    android:inputType="number"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark_text"
                    android:importantForAutofill="no"
                    android:layout_marginEnd="8dp" />

                <!-- Code digit 3 -->
                <!-- Third number box -->
                <EditText
                    android:id="@+id/etCode3"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_security_code_circle"
                    android:gravity="center"
                    android:maxLength="1"
                    android:inputType="number"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark_text"
                    android:importantForAutofill="no"
                    android:layout_marginEnd="8dp" />

                <!-- Code digit 4 -->
                <!-- Fourth number box -->
                <EditText
                    android:id="@+id/etCode4"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_security_code_circle"
                    android:gravity="center"
                    android:maxLength="1"
                    android:inputType="number"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark_text"
                    android:importantForAutofill="no"
                    android:layout_marginEnd="8dp" />

                <!-- Code digit 5 -->
                <!-- Fifth number box -->
                <EditText
                    android:id="@+id/etCode5"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_security_code_circle"
                    android:gravity="center"
                    android:maxLength="1"
                    android:inputType="number"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark_text"
                    android:importantForAutofill="no"
                    android:layout_marginEnd="8dp" />

                <!-- Code digit 6 -->
                <!-- Last number box -->
                <EditText
                    android:id="@+id/etCode6"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_security_code_circle"
                    android:gravity="center"
                    android:maxLength="1"
                    android:inputType="number"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark_text"
                    android:importantForAutofill="no" />
            </LinearLayout>

            <!-- Confirm button -->
            <!-- Main action for this screen -->
            <Button
                android:id="@+id/btnConfirm"
                style="@style/PrimaryButton"
                android:layout_width="match_parent"
                android:text="@string/btn_confirm"
                android:layout_marginTop="40dp" />

            <!-- Send again button -->
            <!-- Secondary action to request a new code -->
            <Button
                android:id="@+id/btnSendAgain"
                style="@style/SecondaryButton"
                android:layout_width="match_parent"
                android:text="@string/btn_send_again"
                android:layout_marginTop="16dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
