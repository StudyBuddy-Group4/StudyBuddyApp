<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_green">

    <!-- Change password screen -->
    <!-- Landscape version -->
    <!-- Full-screen change-password screen -->

    <!-- Header background -->
    <!-- Green top area behind the title -->
    <View
        android:id="@+id/headerBackground"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_gradient_green"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.18"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Back button -->
    <!-- Returns to the previous screen -->
    <!-- Kept in the top-left corner in landscape -->
    <ImageView
        android:id="@+id/ivBack"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:contentDescription="@string/btn_back"
        android:src="@drawable/ic_arrow_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/white" />

    <!-- Screen title -->
    <!-- Centered inside the header area -->
    <!-- Shares the same title treatment as portrait -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/change_password"
        android:textColor="@color/white"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/headerBackground"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/headerBackground" />

    <!-- Scrollable white card -->
    <!-- Holds the full password form -->
    <!-- Lets shorter screens keep the button reachable -->
    <ScrollView
        android:id="@+id/cardContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_card_white"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerBackground">

        <!-- Form content -->
        <!-- Wider horizontal padding keeps the form narrow in landscape -->
        <!-- Vertical stack matches the portrait field order -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="250dp"
            android:paddingTop="24dp"
            android:paddingEnd="250dp"
            android:paddingBottom="24dp">

            <!-- Current password label -->
            <!-- First field in the form -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/current_password"
                style="@style/FieldLabel" />

            <!-- Current password field row -->
            <!-- Input and visibility toggle -->
            <!-- FrameLayout keeps the toggle over the right edge -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <!-- Current password input -->
                <!-- Existing password used for validation -->
                <EditText
                    android:id="@+id/etCurrentPassword"
                    style="@style/InputField"
                    android:importantForAutofill="no"
                    android:inputType="textPassword" />

                <!-- Current password toggle -->
                <!-- Shows or hides the typed password -->
                <ImageView
                    android:id="@+id/ivToggleCurrent"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center_vertical|end"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="@string/password"
                    android:src="@drawable/ic_visibility_off"
                    app:tint="@color/hint_text" />
            </FrameLayout>

            <!-- New password label -->
            <!-- Second field in the form -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/new_password"
                style="@style/FieldLabel" />

            <!-- New password field row -->
            <!-- Matches the current-password row styling -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <!-- New password input -->
                <!-- Receives the replacement password -->
                <EditText
                    android:id="@+id/etNewPassword"
                    style="@style/InputField"
                    android:importantForAutofill="no"
                    android:inputType="textPassword" />

                <!-- New password toggle -->
                <!-- Shows or hides the field -->
                <ImageView
                    android:id="@+id/ivToggleNew"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center_vertical|end"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="@string/password"
                    android:src="@drawable/ic_visibility_off"
                    app:tint="@color/hint_text" />
            </FrameLayout>

            <!-- Confirm password label -->
            <!-- Final field before submit -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/confirm_new_password"
                style="@style/FieldLabel" />

            <!-- Confirm password field row -->
            <!-- Mirrors the new-password row layout -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <!-- Confirm password input -->
                <!-- Repeats the new password for confirmation -->
                <EditText
                    android:id="@+id/etConfirmPassword"
                    style="@style/InputField"
                    android:importantForAutofill="no"
                    android:inputType="textPassword" />

                <!-- Confirm password toggle -->
                <!-- Shows or hides the confirmation field -->
                <ImageView
                    android:id="@+id/ivToggleConfirm"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center_vertical|end"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="@string/password"
                    android:src="@drawable/ic_visibility_off"
                    app:tint="@color/hint_text" />
            </FrameLayout>

            <!-- Primary action -->
            <!-- Submits the password-change form -->
            <!-- Stays below the three password groups -->
            <Button
                android:id="@+id/btnChangePassword"
                style="@style/PrimaryButton"
                android:layout_width="match_parent"
                android:layout_marginTop="32dp"
                android:text="@string/btn_change_password" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
