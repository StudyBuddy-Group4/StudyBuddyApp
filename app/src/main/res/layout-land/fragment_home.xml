<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_top"
    android:gravity="center_horizontal"
    android:orientation="vertical">

    <!-- Home page -->
    <!-- Landscape version scrolls the controls -->
    <!-- Landscape version -->
    <!-- Green gradient stays behind the scroll content -->

    <!-- Screen title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:text="@string/home_page_title"
        android:textColor="@color/dark_text"
        android:textSize="20sp"
        android:textStyle="bold" />

    <!-- Scrollable content -->
    <!-- Keeps the controls reachable on shorter screens -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="ifContentScrolls">

        <!-- Root content -->
        <!-- Adds padding around the card and button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Focus card -->
            <!-- Main card for the timer options -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:background="@drawable/bg_card_rounded"
                android:elevation="4dp"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Focus card header -->
                <!-- Green header inside the white card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_focus_card"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <!-- Clock icon -->
                    <!-- Small icon before the header label -->
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@string/focus_time"
                        android:src="@drawable/ic_clock"
                        app:tint="@color/white" />

                    <!-- Focus time title -->
                    <!-- Header text for the timer section -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/focus_time"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Divider -->
                <!-- Splits the header from the chip row -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"
                    android:background="@color/hint_text" />

                <!-- Time chip row -->
                <!-- Lets the user choose preset or custom time -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <!-- 15-minute chip -->
                    <!-- Default selected option -->
                    <!-- Green color indicates selected -->
                    <TextView
                        android:id="@+id/chip_15_min"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_time_chip_selected"
                        android:paddingStart="20dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="20dp"
                        android:paddingBottom="10dp"
                        android:text="@string/time_15_min"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <!-- 30-minute chip -->
                    <!-- Second preset option -->
                    <!-- White color indicates unselected -->
                    <TextView
                        android:id="@+id/chip_30_min"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/bg_time_chip"
                        android:paddingStart="20dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="20dp"
                        android:paddingBottom="10dp"
                        android:text="@string/time_30_min"
                        android:textColor="@color/dark_text"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <!-- Custom chip -->
                    <!-- Opens the custom duration path -->
                    <TextView
                        android:id="@+id/chip_custom"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/bg_time_chip"
                        android:paddingStart="20dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="20dp"
                        android:paddingBottom="10dp"
                        android:text="@string/time_custom"
                        android:textColor="@color/dark_text"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Start button -->
            <!-- Starts the matching or meeting flow -->
            <Button
                android:id="@+id/btn_start"
                style="@style/PrimaryButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_button_primary"
                android:stateListAnimator="@null"
                android:text="@string/btn_start"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
