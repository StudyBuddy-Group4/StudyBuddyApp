<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_green">

    <!-- Top header background -->
    <View
        android:id="@+id/headerBackground"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_gradient_green"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.18"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Back action -->
    <ImageView
        android:id="@+id/ivBack"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:contentDescription="@string/btn_back"
        android:src="@drawable/ic_arrow_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/white" />

    <!-- Screen title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/delete_account_title"
        android:textColor="@color/white"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/headerBackground"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/headerBackground" />

    <!-- Scrollable white card -->
    <!-- Holds the warning and confirmation form -->
    <ScrollView
        android:id="@+id/cardContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_card_white"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerBackground">

        <!-- Form content -->
        <!-- Wide side padding keeps the landscape card readable -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="250dp"
            android:paddingTop="24dp"
            android:paddingEnd="250dp"
            android:paddingBottom="24dp">

            <!-- Main warning question -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/delete_account_question"
                android:textColor="@color/dark_text"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- Warning box -->
            <!-- Lists the account deletion consequences -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_warning_box"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Warning summary -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/delete_account_warning"
                    android:textColor="@color/secondary_text"
                    android:textSize="13sp" />

                <!-- Consequence item -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="\u2022 All your session history will be eliminated."
                    android:textColor="@color/secondary_text"
                    android:textSize="13sp" />

                <!-- Consequence item -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="\u2022 You will not be able to access your account or any related information."
                    android:textColor="@color/secondary_text"
                    android:textSize="13sp" />

                <!-- Consequence item -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="\u2022 This action cannot be undone."
                    android:textColor="@color/secondary_text"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Password confirmation prompt -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/delete_confirm_prompt"
                android:textColor="@color/dark_text"
                android:textSize="14sp" />

            <!-- Password field row -->
            <!-- Keeps the eye icon over the input -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp">

                <!-- Password input -->
                <EditText
                    android:id="@+id/etPassword"
                    style="@style/InputField"
                    android:hint="@string/password"
                    android:importantForAutofill="no"
                    android:inputType="textPassword" />

                <!-- Password visibility toggle -->
                <ImageView
                    android:id="@+id/ivTogglePassword"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center_vertical|end"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="@string/password"
                    android:src="@drawable/ic_visibility_off"
                    app:tint="@color/hint_text" />
            </FrameLayout>

            <!-- Primary delete action -->
            <Button
                android:id="@+id/btnDeleteAccount"
                style="@style/PrimaryButton"
                android:layout_width="match_parent"
                android:layout_marginTop="24dp"
                android:text="@string/btn_yes_delete" />

            <!-- Secondary cancel action -->
            <Button
                android:id="@+id/btnCancel"
                style="@style/SecondaryButton"
                android:layout_width="match_parent"
                android:layout_marginTop="12dp"
                android:text="@string/btn_cancel" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
