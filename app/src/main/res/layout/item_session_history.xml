<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <!-- Session history row -->
    <!-- Status icon -->
    <ImageView
        android:id="@+id/ivStatusIcon"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:contentDescription="Session status"
        android:src="@drawable/ic_trophy" />

    <!-- Text block -->
    <!-- Holds duration and completion text -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Session duration -->
        <TextView
            android:id="@+id/tvSessionDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Focus Duration: 30:00"
            android:textColor="@color/dark_text"
            android:textSize="15sp"
            android:textStyle="bold" />

        <!-- Session status -->
        <TextView
            android:id="@+id/tvSessionStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Completed"
            android:textColor="@color/primary_green"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Session date -->
    <TextView
        android:id="@+id/tvSessionDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Feb 17 - 2026"
        android:textColor="@color/secondary_text"
        android:textSize="12sp" />

</LinearLayout>
