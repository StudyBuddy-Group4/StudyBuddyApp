<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_green">

    <!-- Meeting room page -->
    <!-- Tablet layout -->
    <!-- Uses larger spacing for wider screens -->
    <!-- Main video stays above the preview row and controls -->

    <!-- Screen title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/meeting_room_title"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Main video area -->
    <!-- Larger margins and a max height keep the tablet layout balanced -->
    <!-- Main stream container -->
    <FrameLayout
        android:id="@+id/mainVideoContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="28dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="28dp"
        android:background="@drawable/bg_video_rounded"
        android:clipToOutline="true"
        android:maxHeight="420dp"
        app:layout_constraintBottom_toTopOf="@id/thumbnailScroll"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle">

        <!-- Timer bubble -->
        <!-- Floats over the top-right corner -->
        <!-- Shows the time left in the current session -->
        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_margin="12dp"
            android:background="@drawable/bg_timer_bubble"
            android:gravity="center"
            android:paddingStart="14dp"
            android:paddingTop="8dp"
            android:paddingEnd="14dp"
            android:paddingBottom="8dp"
            android:text="@string/time_left"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textStyle="bold" />
    </FrameLayout>

    <!-- Thumbnail strip -->
    <!-- Taller to fit larger preview cards -->
    <!-- Sits between the main video and the controls -->
    <!-- Scrolls sideways when there are many participants -->
    <HorizontalScrollView
        android:id="@+id/thumbnailScroll"
        android:layout_width="0dp"
        android:layout_height="112dp"
        android:layout_marginStart="28dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="28dp"
        android:layout_marginBottom="12dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/controlBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Runtime thumbnail container -->
        <!-- Preview cards are added here from code -->
        <!-- Starts empty in the XML -->
        <LinearLayout
            android:id="@+id/thumbnailContainer"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <!-- Bottom control bar -->
    <!-- Leaves extra room on larger screens -->
    <!-- Groups the in-call actions -->
    <!-- Centered near the bottom edge -->
    <LinearLayout
        android:id="@+id/controlBar"
        android:layout_width="wrap_content"
        android:layout_height="62dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_meeting_control"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Speaker toggle -->
        <!-- Turns speaker output on or off -->
        <ImageView
            android:id="@+id/btnSpeaker"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_circle_control"
            android:contentDescription="@string/meeting_room_title"
            android:padding="11dp"
            android:src="@drawable/ic_speaker" />

        <!-- Camera toggle -->
        <!-- Turns the local camera on or off -->
        <ImageView
            android:id="@+id/btnCamera"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_circle_control"
            android:contentDescription="@string/meeting_room_title"
            android:padding="11dp"
            android:src="@drawable/ic_videocam" />

        <!-- Hang-up action -->
        <!-- Ends the current room -->
        <ImageView
            android:id="@+id/btnHangUp"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_circle_red"
            android:contentDescription="@string/meeting_room_title"
            android:padding="11dp"
            android:src="@drawable/ic_call_end" />

        <!-- Microphone toggle -->
        <!-- Turns the microphone on or off -->
        <ImageView
            android:id="@+id/btnMic"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_circle_control"
            android:contentDescription="@string/meeting_room_title"
            android:padding="11dp"
            android:src="@drawable/ic_mic" />

        <!-- Flag-participant action -->
        <!-- Opens the participant reporting flow -->
        <ImageView
            android:id="@+id/btnFlag"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_circle_control"
            android:contentDescription="@string/flag_title"
            android:padding="11dp"
            android:src="@drawable/ic_flag" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
