<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_green">

    <!-- Green gradient header -->
    <View
        android:id="@+id/headerBackground"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_gradient_green"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.18" />

    <ImageView
        android:id="@+id/ivBack"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/ic_arrow_back"
        android:contentDescription="@string/btn_back"
        app:tint="@color/white"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/security_code_title"
        android:textColor="@color/white"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/headerBackground"
        app:layout_constraintBottom_toBottomOf="@id/headerBackground"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- White card container -->
    <ScrollView
        android:id="@+id/cardContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_card_white"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/headerBackground"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="250dp"
            android:paddingTop="24dp"
            android:paddingEnd="250dp"
            android:paddingBottom="24dp"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/enter_security_code"
                android:textColor="@color/dark_text"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp" />

            <!-- Security code input boxes -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="32dp">

                <EditText
                    android:id="@+id/etCode1"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_security_code_circle"
                    android:gravity="center"
                    android:maxLength="1"
                    android:inputType="number"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark_text"
                    android:importantForAutofill="no"
                    android:layout_marginEnd="8dp" />

                <EditText
                    android:id="@+id/etCode2"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_security_code_circle"
                    android:gravity="center"
                    android:maxLength="1"
                    android:inputType="number"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark_text"
                    android:importantForAutofill="no"
                    android:layout_marginEnd="8dp" />

                <EditText
                    android:id="@+id/etCode3"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_security_code_circle"
                    android:gravity="center"
                    android:maxLength="1"
                    android:inputType="number"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark_text"
                    android:importantForAutofill="no"
                    android:layout_marginEnd="8dp" />

                <EditText
                    android:id="@+id/etCode4"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_security_code_circle"
                    android:gravity="center"
                    android:maxLength="1"
                    android:inputType="number"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark_text"
                    android:importantForAutofill="no"
                    android:layout_marginEnd="8dp" />

                <EditText
                    android:id="@+id/etCode5"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_security_code_circle"
                    android:gravity="center"
                    android:maxLength="1"
                    android:inputType="number"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark_text"
                    android:importantForAutofill="no"
                    android:layout_marginEnd="8dp" />

                <EditText
                    android:id="@+id/etCode6"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_security_code_circle"
                    android:gravity="center"
                    android:maxLength="1"
                    android:inputType="number"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark_text"
                    android:importantForAutofill="no" />
            </LinearLayout>

            <!-- Confirm button -->
            <Button
                android:id="@+id/btnConfirm"
                style="@style/PrimaryButton"
                android:layout_width="match_parent"
                android:text="@string/btn_confirm"
                android:layout_marginTop="40dp" />

            <!-- Send Again button -->
            <Button
                android:id="@+id/btnSendAgain"
                style="@style/SecondaryButton"
                android:layout_width="match_parent"
                android:text="@string/btn_send_again"
                android:layout_marginTop="16dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>