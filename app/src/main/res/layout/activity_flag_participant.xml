<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_green"
    android:orientation="vertical">

    <!-- Flag participant screen -->
    <!-- Portrait version -->
    <!-- Shows the other people in the current meeting -->
    <!-- Each visible card can open the report flow -->

    <!-- Top bar -->
    <!-- Back and title row -->
    <!-- Keeps the title centered with a spacer on the right -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp">

        <!-- Back action -->
        <!-- Returns to the meeting room -->
        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:contentDescription="@string/btn_back"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/white" />

        <!-- Screen title -->
        <!-- Main heading for the report screen -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/flag_title"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Right spacer for title centering -->
        <!-- Matches the back icon width -->
        <View
            android:layout_width="28dp"
            android:layout_height="28dp" />
    </LinearLayout>

    <!-- Empty state message -->
    <!-- Shown when there are no other participants to report -->
    <TextView
        android:id="@+id/tvNoParticipants"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="48dp"
        android:text="No other participants in this meeting."
        android:textColor="@color/white"
        android:textSize="16sp"
        android:visibility="gone" />

    <!-- Participant grid area -->
    <!-- Filled with the visible participant slots -->
    <!-- Centers the rows inside the remaining screen space -->
    <LinearLayout
        android:id="@+id/participantGrid"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <!-- First participant row -->
        <!-- Holds the first two visible cards -->
        <LinearLayout
            android:id="@+id/row1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:gravity="center"
            android:orientation="horizontal">

            <!-- Participant slot 1 -->
            <!-- Hidden until this slot is assigned a participant -->
            <FrameLayout
                android:id="@+id/slot1"
                android:layout_width="0dp"
                android:layout_height="150dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:visibility="gone">

                <!-- Rounded video placeholder -->
                <!-- Background shape for the participant card -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_video_rounded" />

                <!-- Participant label -->
                <!-- Shows the uid on top of the card -->
                <TextView
                    android:id="@+id/tvUid1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|center_horizontal"
                    android:layout_marginTop="8dp"
                    android:background="#88000000"
                    android:paddingStart="8dp"
                    android:paddingTop="2dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="2dp"
                    android:textColor="@color/white"
                    android:textSize="13sp" />

                <!-- Flag action -->
                <!-- Opens the reason dialog for this participant -->
                <ImageView
                    android:id="@+id/flagBtn1"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="8dp"
                    android:background="@drawable/bg_circle_control"
                    android:contentDescription="@string/flag_title"
                    android:padding="8dp"
                    android:src="@drawable/ic_flag"
                    app:tint="@color/white" />
            </FrameLayout>

            <!-- Participant slot 2 -->
            <!-- Hidden until this slot is assigned a participant -->
            <FrameLayout
                android:id="@+id/slot2"
                android:layout_width="0dp"
                android:layout_height="150dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:visibility="gone">

                <!-- Rounded video placeholder -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_video_rounded" />

                <!-- Participant label -->
                <!-- Shows the uid on top of the card -->
                <TextView
                    android:id="@+id/tvUid2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|center_horizontal"
                    android:layout_marginTop="8dp"
                    android:background="#88000000"
                    android:paddingStart="8dp"
                    android:paddingTop="2dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="2dp"
                    android:textColor="@color/white"
                    android:textSize="13sp" />

                <!-- Flag action -->
                <!-- Opens the reason dialog for this participant -->
                <ImageView
                    android:id="@+id/flagBtn2"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="8dp"
                    android:background="@drawable/bg_circle_control"
                    android:contentDescription="@string/flag_title"
                    android:padding="8dp"
                    android:src="@drawable/ic_flag"
                    app:tint="@color/white" />
            </FrameLayout>
        </LinearLayout>

        <!-- Second participant row -->
        <!-- Holds the next two visible cards -->
        <LinearLayout
            android:id="@+id/row2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <!-- Participant slot 3 -->
            <!-- Hidden until this slot is assigned a participant -->
            <FrameLayout
                android:id="@+id/slot3"
                android:layout_width="0dp"
                android:layout_height="150dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:visibility="gone">

                <!-- Rounded video placeholder -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_video_rounded" />

                <!-- Participant label -->
                <!-- Shows the uid on top of the card -->
                <TextView
                    android:id="@+id/tvUid3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|center_horizontal"
                    android:layout_marginTop="8dp"
                    android:background="#88000000"
                    android:paddingStart="8dp"
                    android:paddingTop="2dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="2dp"
                    android:textColor="@color/white"
                    android:textSize="13sp" />

                <!-- Flag action -->
                <!-- Opens the reason dialog for this participant -->
                <ImageView
                    android:id="@+id/flagBtn3"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="8dp"
                    android:background="@drawable/bg_circle_control"
                    android:contentDescription="@string/flag_title"
                    android:padding="8dp"
                    android:src="@drawable/ic_flag"
                    app:tint="@color/white" />
            </FrameLayout>

            <!-- Participant slot 4 -->
            <!-- Hidden until this slot is assigned a participant -->
            <FrameLayout
                android:id="@+id/slot4"
                android:layout_width="0dp"
                android:layout_height="150dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:visibility="gone">

                <!-- Rounded video placeholder -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_video_rounded" />

                <!-- Participant label -->
                <!-- Shows the uid on top of the card -->
                <TextView
                    android:id="@+id/tvUid4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|center_horizontal"
                    android:layout_marginTop="8dp"
                    android:background="#88000000"
                    android:paddingStart="8dp"
                    android:paddingTop="2dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="2dp"
                    android:textColor="@color/white"
                    android:textSize="13sp" />

                <!-- Flag action -->
                <!-- Opens the reason dialog for this participant -->
                <ImageView
                    android:id="@+id/flagBtn4"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="8dp"
                    android:background="@drawable/bg_circle_control"
                    android:contentDescription="@string/flag_title"
                    android:padding="8dp"
                    android:src="@drawable/ic_flag"
                    app:tint="@color/white" />
            </FrameLayout>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
