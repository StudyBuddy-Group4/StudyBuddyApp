<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Ready-to-focus dialog -->
    <!-- Dialog title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/ready_to_focus"
        android:textColor="@color/dark_text"
        android:textSize="20sp"
        android:textStyle="bold" />

    <!-- Add-task button -->
    <!-- Opens task creation before the session starts -->
    <Button
        android:id="@+id/btn_add_task"
        style="@style/PrimaryButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_button_primary"
        android:stateListAnimator="@null"
        android:text="@string/btn_add_task"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold" />

    <!-- Start-anyway button -->
    <!-- Lets the user continue without adding a task -->
    <Button
        android:id="@+id/btn_start_anyway"
        style="@style/SecondaryButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_button_secondary"
        android:stateListAnimator="@null"
        android:text="@string/btn_start_anyway"
        android:textColor="@color/primary_green"
        android:textSize="16sp"
        android:textStyle="bold" />

</LinearLayout>
